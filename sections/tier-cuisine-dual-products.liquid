<div
  class="section section--full-width tier-cuisine-dual-products"
  style="
    --tc-dual-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --tc-dual-pad-bot-d: {{ section.settings.padding_bottom_desktop }}px;
    --tc-dual-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --tc-dual-pad-bot-m: {{ section.settings.padding_bottom_mobile }}px;
  "
>
  <div class="tier-cuisine-dual-products__inner page-width">
    {%- if section.settings.heading != blank -%}
      <div class="tier-cuisine-dual-products__heading rte">
        {{ section.settings.heading }}
      </div>
      <div class="tier-cuisine-dual-products__title-line" aria-hidden="true"></div>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="tier-cuisine-dual-products__subheading rte">
        {{ section.settings.subheading }}
      </div>
    {%- endif -%}

    <div class="tier-cuisine-dual-products__rule-full" role="presentation"></div>

    <div class="tier-cuisine-dual-products__grid">
      <div class="tier-cuisine-dual-products__col tier-cuisine-dual-products__col--left">
        <div class="tier-cuisine-dual-products__stack">
          {%- for block in section.blocks -%}
            {%- if block.type == 'left_product' -%}
              <div class="tier-cuisine-dual-products__block" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {% liquid
                    assign img_alt = block.settings.image.alt | default: block.settings.title
                  %}
                  <div
                    class="tier-cuisine-dual-products__circle"
                    style="--tc-circle-bg: {{ section.settings.left_circle_bg }};"
                  >
                    {{
                      block.settings.image
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        class: 'tier-cuisine-dual-products__img',
                        widths: '200, 300, 400, 600, 800',
                        sizes: '(min-width: 750px) 28vw, 60vw',
                        alt: img_alt,
                        width: block.settings.image.width,
                        height: block.settings.image.height
                    }}
                  </div>
                {%- endif -%}

                {%- if block.settings.title != blank -%}
                  <p class="tier-cuisine-dual-products__block-title">{{ block.settings.title | escape }}</p>
                {%- endif -%}

                {%- if block.settings.button_label != blank -%}
                  <div class="tier-cuisine-dual-products__block-spacer" aria-hidden="true"></div>
                  <a
                    class="tier-cuisine-dual-products__btn"
                    href="{{ block.settings.button_link | default: '#' }}"
                    style="
                      --tc-btn-bg: {{ block.settings.button_background }};
                      --tc-btn-border: {{ block.settings.button_background }};
                    "
                  >
                    {{ block.settings.button_label | escape }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.left_footer_text != blank -%}
          <a
            class="tier-cuisine-dual-products__footer-link"
            href="{{ section.settings.left_footer_link | default: '#' }}"
          >
            {{ section.settings.left_footer_text | escape }}
          </a>
        {%- endif -%}
      </div>

      <div class="tier-cuisine-dual-products__divider" role="presentation" aria-hidden="true"></div>

      <div class="tier-cuisine-dual-products__col tier-cuisine-dual-products__col--right">
        <div class="tier-cuisine-dual-products__stack">
          {%- for block in section.blocks -%}
            {%- if block.type == 'right_product' -%}
              <div class="tier-cuisine-dual-products__block" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {% liquid
                    assign img_alt = block.settings.image.alt | default: block.settings.title
                  %}
                  <div
                    class="tier-cuisine-dual-products__circle"
                    style="--tc-circle-bg: {{ section.settings.right_circle_bg }};"
                  >
                    {{
                      block.settings.image
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        class: 'tier-cuisine-dual-products__img',
                        widths: '200, 300, 400, 600, 800',
                        sizes: '(min-width: 750px) 28vw, 60vw',
                        alt: img_alt,
                        width: block.settings.image.width,
                        height: block.settings.image.height
                    }}
                  </div>
                {%- endif -%}

                {%- if block.settings.title != blank -%}
                  <p class="tier-cuisine-dual-products__block-title">{{ block.settings.title | escape }}</p>
                {%- endif -%}

                {%- if block.settings.button_label != blank -%}
                  <div class="tier-cuisine-dual-products__block-spacer" aria-hidden="true"></div>
                  <a
                    class="tier-cuisine-dual-products__btn"
                    href="{{ block.settings.button_link | default: '#' }}"
                    style="
                      --tc-btn-bg: {{ block.settings.button_background }};
                      --tc-btn-border: {{ block.settings.button_background }};
                    "
                  >
                    {{ block.settings.button_label | escape }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.right_footer_text != blank -%}
          <a
            class="tier-cuisine-dual-products__footer-link"
            href="{{ section.settings.right_footer_link | default: '#' }}"
          >
            {{ section.settings.right_footer_text | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .tier-cuisine-dual-products {
    padding-block-start: var(--tc-dual-pad-top-m);
    padding-block-end: var(--tc-dual-pad-bot-m);
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-dual-products {
      padding-block-start: var(--tc-dual-pad-top-d);
      padding-block-end: var(--tc-dual-pad-bot-d);
    }
  }

  .tier-cuisine-dual-products__inner {
    max-width: 100%;
  }

  .tier-cuisine-dual-products__heading.rte {
    font-family: var(--font-family);
    font-weight: 700;
    font-size: clamp(1.75rem, 5vw, 2.9375rem);
    line-height: 130%;
    text-align: center;
    color: #000;
    margin: 0 0 1rem;
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-dual-products__heading.rte {
      font-size: 47px;
    }
  }

  .tier-cuisine-dual-products__heading.rte p {
    margin: 0;
    font-family: inherit;
    font-weight: inherit;
    font-size: inherit;
    line-height: inherit;
    text-align: inherit;
    color: inherit;
  }

  .tier-cuisine-dual-products__heading.rte em,
  .tier-cuisine-dual-products__heading.rte i {
    font-family: var(--second-family);
    font-style: italic;
  }

  .tier-cuisine-dual-products__title-line {
    width: 124px;
    height: 0;
    margin: 0 auto 1.25rem;
    border: none;
    border-bottom: 2px solid var(--tiercuisine-gold-500);
  }

  .tier-cuisine-dual-products__subheading.rte {
    font-family: var(--font-family);
    font-weight: 400;
    font-size: clamp(1.25rem, 3.5vw, 2.25rem);
    line-height: 130%;
    text-align: center;
    color: #000;
    margin: 0 auto 1.5rem;
    max-width: 48rem;
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-dual-products__subheading.rte {
      font-size: 36px;
    }
  }

  .tier-cuisine-dual-products__subheading.rte p {
    margin: 0;
    font-family: inherit;
    font-weight: inherit;
    font-size: inherit;
    line-height: inherit;
    text-align: inherit;
    color: inherit;
  }

  .tier-cuisine-dual-products__rule-full {
    width: 100%;
    height: 0;
    border: none;
    border-top: 1px solid var(--tiercuisine-gold-500);
  }

  .tier-cuisine-dual-products__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    align-items: start;
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-dual-products__grid {
      grid-template-columns: 1fr 1px 1fr;
      column-gap: 0;
    }
  }

  .tier-cuisine-dual-products__divider {
    width: 100%;
    height: 1px;
    margin: 2rem 0;
    background: var(--tiercuisine-gold-500);
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-dual-products__divider {
      width: 1px;
      height: 100%;
      min-height: 12rem;
      margin: 0;
      align-self: stretch;
      justify-self: center;
    }
  }

  .tier-cuisine-dual-products__stack {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: stretch;
    justify-content: center;
    gap: 60px;
    width: 90%;
    flex: 1 1 auto;
  }

  .tier-cuisine-dual-products__block {
    flex: 1 1 0;
    min-width: 0;
    max-width: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    align-self: stretch;
  }

  .tier-cuisine-dual-products__circle {
    width: min(100%, 179px);
    aspect-ratio: 1;
    border-radius: 50%;
    /* background: var(--tc-circle-bg, var(--tiercuisine-brightgreen---300)); */
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-bottom: 20px;
  }

  .tier-cuisine-dual-products__block-spacer {
    flex: 1 1 auto;
    min-height: 0;
    width: 100%;
  }

  .tier-cuisine-dual-products__block-title + .tier-cuisine-dual-products__block-spacer {
    margin-top: 7px;
  }

  .tier-cuisine-dual-products__img {
    width: 100%;
    height: auto;
    max-height: 100%;
    object-fit: contain;
  }

  @media screen and (min-width: 1024px) {
    .tier-cuisine-dual-products__img {
      min-width: 179px;
    }
  }

  @media screen and (max-width: 749px) {
    .tier-cuisine-dual-products__stack {
      flex-direction: column;
      align-items: center;
    }

    .tier-cuisine-dual-products__block {
      flex: none;
      width: 100%;
      max-width: 22rem;
    }
  }

  .tier-cuisine-dual-products__block-title {
    font-family: var(--font-family);
    font-weight: 400;
    font-size: clamp(1.0625rem, 2.5vw, 1.5rem);
    line-height: 1.3;
    text-align: center;
    color: #000;
    margin: 0;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-dual-products__block-title {
      font-size: 24px;
    }
  }

  .tier-cuisine-dual-products__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: center;
    flex-shrink: 0;
    box-sizing: border-box;
    min-width: 88px;
    height: 33px;
    padding: 0 0.75rem;
    border: 1px solid var(--tc-btn-border, var(--tiercuisine-gold-500));
    border-radius: 23px;
    background: var(--tc-btn-bg, var(--tiercuisine-gold-500));
    font-family: var(--font-family);
    font-weight: 500;
    font-size: 17px;
    line-height: 143%;
    letter-spacing: 0.12em;
    text-align: center;
    text-decoration: none;
    color: #fff;
    transition: opacity 0.2s ease;
  }

  .tier-cuisine-dual-products__btn:hover {
    opacity: 0.9;
  }

  .tier-cuisine-dual-products__footer-link {
    display: block;
    margin-top: 72px;
    font-family: var(--font-family);
    font-weight: 400;
    font-size: 16px;
    text-decoration: underline;
    text-decoration-skip-ink: none;
    text-align: center;
    color: #000;
  }

  .tier-cuisine-dual-products__col {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
    min-width: 0;
    height: 100%;
    overflow: hidden;
    padding-top: 30px;
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-dual-products__col {
      padding-top: 60px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 1279px) {
    .tier-cuisine-dual-products__stack {
      flex-wrap: wrap;
      align-content: flex-start;
      justify-content: center;
      row-gap: 2.5rem;
    }

    .tier-cuisine-dual-products__block {
      flex: 0 0 calc((100% - 70px) / 2);
      max-width: calc((100% - 70px) / 2);
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .tier-cuisine-dual-products__stack {
      flex-wrap: nowrap;
      flex-direction: column;
      row-gap: 0;
    }

    .tier-cuisine-dual-products__block {
      flex: none;
      max-width: 22rem;
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tier Cuisine dual grid",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Padding — desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    },
    {
      "type": "header",
      "content": "Padding — mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "Intro"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Title",
      "default": "<p>Tierarzt-Knowhow trifft <em>Kochkunst</em>:</p>"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subtitle",
      "default": "<p>Premiumfutter für gesunde und glückliche Hunde &amp; Katzen.</p>"
    },
    {
      "type": "header",
      "content": "Column image circles"
    },
    {
      "type": "color",
      "id": "left_circle_bg",
      "label": "Left column circle background",
      "default": "#e3e5ce"
    },
    {
      "type": "color",
      "id": "right_circle_bg",
      "label": "Right column circle background",
      "default": "#e5e4e0"
    },
    {
      "type": "header",
      "content": "Footer links"
    },
    {
      "type": "text",
      "id": "left_footer_text",
      "label": "Left column link text",
      "default": "Zu allen Produkten für Katzen"
    },
    {
      "type": "url",
      "id": "left_footer_link",
      "label": "Left column link"
    },
    {
      "type": "text",
      "id": "right_footer_text",
      "label": "Right column link text",
      "default": "Zu allen Produkten für Hunde"
    },
    {
      "type": "url",
      "id": "right_footer_link",
      "label": "Right column link"
    }
  ],
  "blocks": [
    {
      "type": "left_product",
      "name": "Left column item",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Vital Snacks"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "KATZE"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "color",
          "id": "button_background",
          "label": "Button background",
          "default": "#d2bd92"
        }
      ]
    },
    {
      "type": "right_product",
      "name": "Right column item",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Vital Snacks"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "HUND"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "color",
          "id": "button_background",
          "label": "Button background",
          "default": "#665750"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tier Cuisine dual grid",
      "category": "Banners"
    }
  ]
}
{% endschema %}
