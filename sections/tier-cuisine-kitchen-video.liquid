{%- liquid
  assign kv_video = section.settings.video
  assign kv_cover = section.settings.cover_image
  assign kv_poster = kv_cover
  if kv_poster == blank and kv_video != blank
    assign kv_poster = kv_video.preview_image
  endif
  assign kv_poster_alt = ''
  if kv_cover != blank
    assign kv_poster_alt = kv_cover.alt | default: ''
  elsif kv_video != blank
    assign kv_poster_alt = kv_video.alt | default: ''
  endif
  assign kv_sources_count = 0
  if kv_video != blank
    assign kv_sources_count = kv_video.sources | size
  endif
-%}

<div
  class="section section--full-width tier-cuisine-kitchen-video"
  id="TierCuisineKitchenVideo-{{ section.id }}"
  style="
    --tc-kv-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --tc-kv-pad-bot-d: {{ section.settings.padding_bottom_desktop }}px;
    --tc-kv-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --tc-kv-pad-bot-m: {{ section.settings.padding_bottom_mobile }}px;
    --tc-kv-bg: {{ section.settings.section_background }};
  "
>
  <div class="tier-cuisine-kitchen-video__top">
    <div class="tier-cuisine-kitchen-video__inner page-width">
      {%- if section.settings.title != blank -%}
        <div class="tier-cuisine-kitchen-video__title rte">
          {{ section.settings.title }}
        </div>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <div class="tier-cuisine-kitchen-video__subtitle rte">
          {{ section.settings.subtitle }}
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if kv_video != blank or kv_cover != blank -%}
    <div class="tier-cuisine-kitchen-video__media-wrap page-width">
      <div class="tier-cuisine-kitchen-video__media" data-tc-kitchen-video-root>
        <span class="tier-cuisine-kitchen-video__media-aspect" aria-hidden="true"></span>

        {%- comment -%}
          Спочатку «лише прев’ю» (нема вибраного відео), щоб image_picker завжди відображався.
        {%- endcomment -%}
        {%- if kv_cover != blank and kv_video == blank -%}
          {{
            kv_cover
            | image_url: width: 2000
            | image_tag:
              loading: 'lazy',
              class: 'tier-cuisine-kitchen-video__poster tier-cuisine-kitchen-video__poster--only',
              widths: '400, 600, 800, 1000, 1200, 1600, 2000',
              sizes: '(min-width: 1200px) min(90vw, 1200px), 92vw',
              alt: kv_poster_alt
          }}
        {%- elsif kv_video != blank and kv_sources_count > 0 -%}
          <video
            class="tier-cuisine-kitchen-video__el"
            playsinline
            preload="metadata"
            {% if kv_poster != blank %}
              poster="{{ kv_poster | image_url: width: 2000 }}"
            {% endif %}
            data-tc-kitchen-video
          >
            {%- for source in kv_video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        {%- elsif kv_video != blank -%}
          <div class="tier-cuisine-kitchen-video__embed">
            {{ kv_video | video_tag: image_size: '2500x', autoplay: false, loop: false, muted: false, controls: true, class: 'tier-cuisine-kitchen-video__el' }}
          </div>
        {%- endif -%}

        {%- if kv_video != blank and kv_sources_count > 0 -%}
          <div class="tier-cuisine-kitchen-video__overlay" data-tc-kitchen-overlay>
            <button
              type="button"
              class="tier-cuisine-kitchen-video__play-btn"
              data-tc-kitchen-play
              aria-label="{{ section.settings.video_play_label | default: 'Video abspielen' | escape }}"
            >
              <svg
                class="tier-cuisine-kitchen-video__play-svg"
                width="193"
                height="193"
                viewBox="0 0 193 193"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M96.4999 176.917C140.913 176.917 176.917 140.913 176.917 96.5002C176.917 52.0873 140.913 16.0835 96.4999 16.0835C52.087 16.0835 16.0832 52.0873 16.0832 96.5002C16.0832 140.913 52.087 176.917 96.4999 176.917Z" fill="#D2BD92" fill-opacity="0.28" stroke="white" stroke-width="7" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M80.4167 64.3335L128.667 96.5002L80.4167 128.667V64.3335Z" stroke="white" stroke-width="7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
            {%- if section.settings.video_cta_label != blank -%}
              <span class="tier-cuisine-kitchen-video__pill">
                {{ section.settings.video_cta_label | escape }}
              </span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</div>

{%- if kv_video != blank and kv_sources_count > 0 -%}
  <script>
    (() => {
      const root = document.querySelector('#TierCuisineKitchenVideo-{{ section.id }} [data-tc-kitchen-video-root]');
      if (!root) return;
      const video = root.querySelector('[data-tc-kitchen-video]');
      const overlay = root.querySelector('[data-tc-kitchen-overlay]');
      const btn = root.querySelector('[data-tc-kitchen-play]');
      if (!video || !overlay || !btn) return;

      const play = () => {
        video.setAttribute('controls', 'controls');
        video.play().catch(() => {});
        overlay.classList.add('tier-cuisine-kitchen-video__overlay--hide');
      };

      btn.addEventListener('click', play);
      video.addEventListener('play', () => {
        overlay.classList.add('tier-cuisine-kitchen-video__overlay--hide');
      });
    })();
  </script>
{%- endif -%}

{% stylesheet %}
  .tier-cuisine-kitchen-video {
    position: relative;
    z-index: 1;
    overflow: visible;
    padding-block-end: var(--tc-kv-pad-bot-m);
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-kitchen-video {
      padding-block-end: var(--tc-kv-pad-bot-d);
    }
  }

  .tier-cuisine-kitchen-video__top {
    background-color: var(--tc-kv-bg);
    padding-block-start: var(--tc-kv-pad-top-m);
    padding-block-end: 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-kitchen-video__top {
      padding-block-start: var(--tc-kv-pad-top-d);
      padding-block-end: 2rem;
    }
  }

  .tier-cuisine-kitchen-video__inner {
    max-width: 72rem;
    margin-inline: auto;
  }

  .tier-cuisine-kitchen-video__title.rte {
    margin: 0;
    font-family: var(--font-family);
    font-weight: 500;
    font-size: clamp(1.75rem, 5vw, 48px);
    line-height: 130%;
    text-align: center;
    color: var(--tc-almost-black-500);
  }

  .tier-cuisine-kitchen-video__title.rte p {
    margin: 0;
  }

  .tier-cuisine-kitchen-video__title.rte em,
  .tier-cuisine-kitchen-video__title.rte i {
    font-family: var(--second-family);
    font-style: italic;
    font-weight: 400;
  }

  .tier-cuisine-kitchen-video__subtitle.rte {
    margin: 1rem 0 0;
    font-family: var(--font-family);
    font-weight: 400;
    font-size: 16px;
    line-height: 150%;
    text-align: center;
    color: var(--tc-almost-black-500);
  }

  .tier-cuisine-kitchen-video__subtitle.rte p {
    margin: 0;
  }

  .tier-cuisine-kitchen-video__media-wrap {
    position: relative;
    z-index: 2;
    max-width: 72rem;
    margin-inline: auto;
    margin-top: -1.25rem;
    margin-bottom: clamp(-3.5rem, -10vw, -7rem);
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-kitchen-video__media-wrap {
      margin-top: -1.75rem;
      margin-bottom: clamp(-5rem, -12vw, -8.5rem);
    }
  }

  .tier-cuisine-kitchen-video__media {
    position: relative;
    display: block;
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgb(0 0 0 / 14%);
    text-decoration: none;
    color: inherit;
  }

  .tier-cuisine-kitchen-video__media-aspect {
    display: block;
    padding-bottom: 56.25%;
    width: 100%;
    height: 0;
  }

  .tier-cuisine-kitchen-video__el,
  .tier-cuisine-kitchen-video__poster--only {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tier-cuisine-kitchen-video__el {
    background: #000;
  }

  .tier-cuisine-kitchen-video__embed {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .tier-cuisine-kitchen-video__embed video,
  .tier-cuisine-kitchen-video__embed iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tier-cuisine-kitchen-video__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }

  .tier-cuisine-kitchen-video__overlay--hide {
    opacity: 0;
    visibility: hidden;
  }

  .tier-cuisine-kitchen-video__play-btn {
    pointer-events: auto;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    line-height: 0;
  }

  .tier-cuisine-kitchen-video__play-svg {
    width: min(120px, 28vw);
    height: auto;
    max-width: 100%;
    filter: drop-shadow(0 4px 16px rgb(0 0 0 / 25%));
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-kitchen-video__play-svg {
      width: min(193px, 22vw);
    }
  }

  .tier-cuisine-kitchen-video__pill {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    background: rgb(255 255 255 / 92%);
    font-family: var(--font-family);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--tc-almost-black-500);
    white-space: nowrap;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .tier-cuisine-kitchen-video__media-wrap {
      margin-inline: 0.75rem;
    }

    .tier-cuisine-kitchen-video__pill {
      font-size: 10px;
      padding: 0.4rem 0.85rem;
      bottom: 0.65rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TC kitchen video",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Padding — desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "Padding — mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    },
    {
      "type": "header",
      "content": "Background & text"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "alpha": true,
      "default": "#e8dfd4"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>In unserer <em>Küche mit Liebe & Sorgfalt</em> für dein Tier komponiert und entwickelt</p>"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Der Weg zur Gesundheit führt durch die Küche</p>"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video file",
      "info": "Upload a video file. Custom play button shows for uploaded MP4/WebM; other sources use standard player."
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Preview image",
      "info": "Required if no video file is selected — the block shows this image. With a video, it is used as the poster/cover when set."
    },
    {
      "type": "text",
      "id": "video_play_label",
      "label": "Play button accessibility label",
      "default": "Video abspielen"
    },
    {
      "type": "text",
      "id": "video_cta_label",
      "label": "Label on video (optional)",
      "default": "VIDEO ANSEHEN"
    }
  ],
  "presets": [
    {
      "name": "TC kitchen video",
      "category": "Storytelling"
    }
  ]
}
{% endschema %}
