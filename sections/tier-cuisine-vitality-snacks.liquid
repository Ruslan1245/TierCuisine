<div
  class="section section--full-width tier-cuisine-vitality-snacks"
  id="TierCuisineVitalitySnacks-{{ section.id }}"
  style="
    --tc-vs-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --tc-vs-pad-bot-d: {{ section.settings.padding_bottom_desktop }}px;
    --tc-vs-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --tc-vs-pad-bot-m: {{ section.settings.padding_bottom_mobile }}px;
    --tc-vs-svg-gap: {{ section.settings.svg_gap }}px;
  "
>
  <div class="tier-cuisine-vitality-snacks__inner">
    {%- if section.settings.badge != blank -%}
      <p class="tier-cuisine-vitality-snacks__badge">{{ section.settings.badge | escape }}</p>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h2 class="tier-cuisine-vitality-snacks__title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <div class="tier-cuisine-vitality-snacks__subtitle rte">
        {{ section.settings.subtitle }}
      </div>
    {%- endif -%}

    {%- if section.settings.svg_code_left != blank or section.settings.svg_code_right != blank -%}
      <div class="tier-cuisine-vitality-snacks__svg-row">
        {%- if section.settings.svg_code_left != blank -%}
          <div class="tier-cuisine-vitality-snacks__svg-cell">
            <div class="tier-cuisine-vitality-snacks__svg-inline">
              {% # theme-check-disable UnknownFilter %}
              {{ section.settings.svg_code_left | strip | raw }}
              {% # theme-check-enable UnknownFilter %}
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.svg_code_right != blank -%}
          <div class="tier-cuisine-vitality-snacks__svg-cell">
            <div class="tier-cuisine-vitality-snacks__svg-inline">
              {% # theme-check-disable UnknownFilter %}
              {{ section.settings.svg_code_right | strip | raw }}
              {% # theme-check-enable UnknownFilter %}
            </div>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .tier-cuisine-vitality-snacks {
    padding-block-start: var(--tc-vs-pad-top-m);
    padding-block-end: var(--tc-vs-pad-bot-m);
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-vitality-snacks {
      padding-block-start: var(--tc-vs-pad-top-d);
      padding-block-end: var(--tc-vs-pad-bot-d);
    }
  }

  .tier-cuisine-vitality-snacks__inner {
    max-width: 52rem;
    margin-inline: auto;
    padding-inline: 1.25rem;
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    .tier-cuisine-vitality-snacks__inner {
      padding-inline: 2.5rem;
    }
  }

  .tier-cuisine-vitality-snacks__badge {
    margin: 0 0 38px;
    font-family: var(--font-family);
    font-weight: 400;
    font-size: 16px;
    text-align: center;
    color: #000;
  }

  .tier-cuisine-vitality-snacks__title {
    margin: 0 0 40px;
    font-family: var(--font-family);
    font-weight: 500;
    font-size: clamp(1.75rem, 5vw, 48px);
    text-align: center;
    color: var(--tc-almost-black-500);
    line-height: 1.2;
  }

  .tier-cuisine-vitality-snacks__subtitle.rte {
    margin: 0;
    font-family: var(--font-family);
    font-weight: 400;
    font-size: 18px;
    line-height: 150%;
    text-align: center;
    color: var(--tc-almost-black-500);
  }

  @media screen and (max-width: 749px) {
    .tier-cuisine-vitality-snacks__subtitle.rte {
      font-size: 16px;
    }

    .tier-cuisine-vitality-snacks__badge {
      margin-bottom: 1.5rem;
    }

    .tier-cuisine-vitality-snacks__title {
      margin-bottom: 2.5rem;
    }
  }

  .tier-cuisine-vitality-snacks__subtitle.rte p {
    margin: 0;
  }

  .tier-cuisine-vitality-snacks__subtitle.rte strong {
    font-weight: 700;
  }

  .tier-cuisine-vitality-snacks__svg-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 170px;
    margin-top: clamp(2rem, 5vw, 3.5rem);
    @media (max-width: 750px) {
      gap: 70px;
      flex-wrap: wrap;
      @media (max-width: 550px) {
        gap: 40px;
      }
    }
  }

  .tier-cuisine-vitality-snacks__svg-cell {
    flex: 1 1 auto;
    min-width: min(100%, 12rem);
    max-width: min(100%, 28rem);
    display: flex;
    justify-content: center;
  }

  .tier-cuisine-vitality-snacks__svg-inline {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .tier-cuisine-vitality-snacks__svg-inline svg {
    width: 100%;
    height: auto;
    max-width: 100%;
    display: block;
    @media (max-width: 750px) {
      width: 75%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "TC vitality text + SVG",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Padding — desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "Padding — mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Gesunde Vitality Snacks mit Wirkung"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Mit Gesundheit belohnen"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Dein Text mit <strong>fett hervorgehobenen</strong> Stellen.</p>"
    },
    {
      "type": "header",
      "content": "SVG illustrations"
    },
    {
      "type": "textarea",
      "id": "svg_code_left",
      "label": "SVG code (left)",
      "info": "Paste the full inline SVG markup (starts with <svg ...>)."
    },
    {
      "type": "textarea",
      "id": "svg_code_right",
      "label": "SVG code (right)",
      "info": "Paste the full inline SVG markup (starts with <svg ...>)."
    },
    {
      "type": "range",
      "id": "svg_gap",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Gap between images",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "TC vitality text + SVG",
      "category": "Custom"
    }
  ]
}
{% endschema %}
